# Copy this to .env.local and fill in real values, or run:
#   vercel link && vercel env pull apps/web/.env.local
# (requires the Neon Postgres + Vercel Blob integrations to be provisioned on the linked project)

# Neon Postgres — pooled connection, used at runtime by the app
DATABASE_URL=

# Neon Postgres — unpooled/direct connection, used only by Prisma Migrate
DATABASE_URL_UNPOOLED=

# Vercel Blob — used for attachment uploads (PDFs, images, brochures, floor plans)
BLOB_READ_WRITE_TOKEN=

# Vercel AI Gateway — used to parse pasted project data into structured projects
# Get a key at https://vercel.com/d?to=%2F%5Bteam%5D%2F%7E%2Fai-gateway%2Fapi-keys
# Not needed when deployed on Vercel (uses OIDC automatically)
AI_GATEWAY_API_KEY=

# Admin password — the INITIAL password for the seeded owner account
# (admin@trixishomes.com). Sign-in is now per-user email + password; seed with:
#   cd packages/db && pnpm tsx prisma/seed-users.ts
ADMIN_PASSWORD=

# Optional: email for the seeded owner account. Defaults to admin@trixishomes.com.
OWNER_EMAIL=

# Optional: secret for signing session cookies. Defaults to ADMIN_PASSWORD;
# set separately so rotating the password doesn't invalidate sessions.
# Copy the same value into apps/marketing so the public site can recognise a
# signed-in user and show its "Back to admin" bar.
AUTH_SECRET=

# Production only: share the session cookie with the public site on a sibling
# host, e.g. ".trixishomes.com" when the dashboard is at app.trixishomes.com.
# Leave blank in dev — localhost:3000 and :3001 already share cookies.
SESSION_COOKIE_DOMAIN=

# Resend — sends password-reset OTP emails. Without a key, codes are printed to
# the server log (fine for dev). Create a key at https://resend.com/api-keys and
# verify the trixishomes.com sending domain. EMAIL_FROM must use a verified domain.
RESEND_API_KEY=
EMAIL_FROM="Trixis Homes <no-reply@trixishomes.com>"

# Vercel Web Analytics — powers the /analytics dashboard's visitor metrics.
# Create a token at https://vercel.com/account/tokens; project id is the
# marketing project's, team id from your Vercel team settings.
VERCEL_API_TOKEN=
VERCEL_MARKETING_PROJECT_ID=
VERCEL_TEAM_ID=

# Public marketing site the app logo links back to.
# Defaults to https://trixishomes.com; .env.development sets localhost:3001 for dev.
NEXT_PUBLIC_MARKETING_URL=
