# Copy this to .env.local and fill in real values, or run:
#   vercel link && vercel env pull apps/web/.env.local
# (requires the Neon Postgres + Vercel Blob integrations to be provisioned on the linked project)

# Neon Postgres — pooled connection, used at runtime by the app
DATABASE_URL=

# Neon Postgres — unpooled/direct connection, used only by Prisma Migrate
DATABASE_URL_UNPOOLED=

# Vercel Blob — used for attachment uploads (PDFs, images, brochures, floor plans)
BLOB_READ_WRITE_TOKEN=

# Vercel AI Gateway — used to parse pasted project data into structured projects
# Get a key at https://vercel.com/d?to=%2F%5Bteam%5D%2F%7E%2Fai-gateway%2Fapi-keys
# Not needed when deployed on Vercel (uses OIDC automatically)
AI_GATEWAY_API_KEY=

# Admin password — unlocks editing (login at /login). Without it the app is view-only.
ADMIN_PASSWORD=

# Optional: secret for signing admin session cookies. Defaults to ADMIN_PASSWORD;
# set separately so rotating the password doesn't invalidate sessions.
AUTH_SECRET=

# Public marketing site the app logo links back to.
# Defaults to https://trixishomes.com; .env.development sets localhost:3001 for dev.
NEXT_PUBLIC_MARKETING_URL=
