generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  moduleFormat        = "esm"
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

enum ProjectStatus {
  OFF_PLAN
  UNDER_CONSTRUCTION
  READY
}

enum PropertyType {
  APARTMENT
  TOWNHOUSE
  VILLA
  PENTHOUSE
  DUPLEX
  OFFICE
  RETAIL
  OTHER
}

enum AttachmentCategory {
  BROCHURE
  FLOOR_PLAN
  IMAGE
  PRICE_LIST
  OTHER
}

enum PaymentMilestoneTiming {
  ON_BOOKING
  DURING_CONSTRUCTION
  ON_HANDOVER
  AFTER_HANDOVER
  FIXED_DATE
}

model Project {
  id                      String        @id @default(cuid())
  name                    String
  developer               String
  community               String?
  city                    String?
  location                String
  latitude                Float?
  longitude               Float?
  status                  ProjectStatus @default(OFF_PLAN)
  handoverDate            DateTime?
  description             String?
  paymentPlan             String?
  downPaymentPercent      Decimal?      @db.Decimal(5, 2)
  promoPaymentPlan        String?
  promoDownPaymentPercent Decimal?      @db.Decimal(5, 2)
  promotionNotes          String?
  serviceCharge           Decimal?      @db.Decimal(10, 2)
  amenities               String[]      @default([])
  sellingPoints           String[]      @default([])
  investmentRating        Int?
  luxuryRating            Int?
  familyRating            Int?
  waterfront              Boolean       @default(false)
  golf                    Boolean       @default(false)
  brandedResidence        Boolean       @default(false)
  brandName               String?
  availableUnitsCount     Int?
  link                    String?
  isFavorite              Boolean       @default(false)

  unitTypes         UnitType[]
  notes             Note[]
  attachments       Attachment[]
  paymentMilestones PaymentMilestone[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isFavorite])
  @@index([developer])
  @@index([location])
  @@index([city])
  @@index([status])
  @@index([waterfront])
  @@index([golf])
  @@index([brandedResidence])
}

model UnitType {
  id            String       @id @default(cuid())
  projectId     String
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  propertyType  PropertyType @default(APARTMENT)
  label         String?
  unitCount     Int?
  startingPrice Decimal      @db.Decimal(14, 2)
  size          Decimal?     @db.Decimal(10, 2)
  plotSize      Decimal?     @db.Decimal(10, 2)
  bua           Decimal?     @db.Decimal(10, 2)
  bedrooms      Int?
  bathrooms     Int?
  parking       Int?
  paymentPlan   String?
  serviceCharge Decimal?     @db.Decimal(10, 2)
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model PaymentMilestone {
  id           String                 @id @default(cuid())
  projectId    String
  project      Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label        String
  percentage   Decimal                @db.Decimal(5, 2)
  timing       PaymentMilestoneTiming @default(ON_HANDOVER)
  offsetMonths Int?
  fixedDate    DateTime?
  note         String?
  sortOrder    Int                    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model Note {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  body      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model Attachment {
  id          String             @id @default(cuid())
  projectId   String
  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  filename    String
  url         String
  pathname    String
  contentType String
  size        Int
  category    AttachmentCategory @default(OTHER)
  isCover     Boolean            @default(false)

  uploadedAt DateTime @default(now())

  @@index([projectId])
}
