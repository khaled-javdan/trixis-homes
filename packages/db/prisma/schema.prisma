generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  moduleFormat        = "esm"
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

enum ProjectStatus {
  OFF_PLAN
  UNDER_CONSTRUCTION
  READY
}

enum PropertyType {
  APARTMENT
  TOWNHOUSE
  VILLA
  PENTHOUSE
  DUPLEX
  OFFICE
  RETAIL
  OTHER
}

enum AttachmentCategory {
  BROCHURE
  FLOOR_PLAN
  IMAGE
  PRICE_LIST
  OTHER
}

enum LeadType {
  BROCHURE
  FLOOR_PLAN
  PRICE_LIST
  ENQUIRY
}

model Project {
  id                      String        @id @default(cuid())
  name                    String
  developer               String
  masterCommunity         String?
  community               String?
  city                    String?
  location                String
  latitude                Float?
  longitude               Float?
  status                  ProjectStatus @default(OFF_PLAN)
  launchDate              DateTime?
  handoverDate            DateTime?
  description             String?
  paymentPlan             String?
  downPaymentPercent      Decimal?      @db.Decimal(5, 2)
  promoPaymentPlan        String?
  promoDownPaymentPercent Decimal?      @db.Decimal(5, 2)
  promotionNotes          String?
  serviceCharge           Decimal?      @db.Decimal(10, 2)
  amenities               String[]      @default([])
  sellingPoints           String[]      @default([])
  investmentRating        Int?
  luxuryRating            Int?
  familyRating            Int?
  waterfront              Boolean       @default(false)
  golf                    Boolean       @default(false)
  brandedResidence        Boolean       @default(false)
  brandName               String?
  availableUnitsCount     Int?
  link                    String?
  isFavorite              Boolean       @default(false)
  inventoryUpdatedAt      DateTime?
  isPublished             Boolean       @default(false)
  // Featured in the home-page "hot projects" slider (only when published).
  isHot                   Boolean       @default(false)
  slug                    String?       @unique

  unitTypes         UnitType[]
  notes             Note[]
  attachments       Attachment[]
  paymentMilestones PaymentMilestone[]
  leads             Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isFavorite])
  @@index([isPublished])
  @@index([developer])
  @@index([masterCommunity])
  @@index([location])
  @@index([city])
  @@index([status])
  @@index([waterfront])
  @@index([golf])
  @@index([brandedResidence])
}

model UnitType {
  id            String       @id @default(cuid())
  projectId     String
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  propertyType  PropertyType @default(APARTMENT)
  label         String?
  unitCount     Int?
  startingPrice Decimal      @db.Decimal(14, 2)
  size          Decimal?     @db.Decimal(10, 2)
  plotSize      Decimal?     @db.Decimal(10, 2)
  bua           Decimal?     @db.Decimal(10, 2)
  bedrooms      Int?
  bathrooms     Int?
  parking       Int?
  paymentPlan   String?
  serviceCharge Decimal?     @db.Decimal(10, 2)
  notes         String?
  listingUrl    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model PaymentMilestone {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label      String
  percentage Decimal  @db.Decimal(5, 2)
  date       DateTime
  note       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model Note {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  body      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

// Editorial content for a developer brand, configured in the admin app and
// rendered on the public /developers page. Matched to Project.developer by
// loose (case-insensitive contains) name comparison, not a foreign key, so
// projects don't need re-linking when names differ slightly.
model Developer {
  id            String  @id @default(cuid())
  name          String  @unique
  description   String?
  coverImageUrl String?
  logoUrl       String?
  websiteUrl    String?
  // Hidden developers keep their content but don't render publicly.
  isVisible     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  // Optional: enquiry/callback requests only need a phone number, while gated
  // downloads (brochure/floor plan/price list) require an email to deliver to.
  email     String?
  phone     String?
  message   String?
  type      LeadType @default(ENQUIRY)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  // Kept denormalized so the lead's context survives project deletion.
  projectName String?

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([email])
  @@index([createdAt])
}

model Attachment {
  id          String             @id @default(cuid())
  projectId   String
  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  filename    String
  url         String
  pathname    String
  contentType String
  size        Int
  category    AttachmentCategory @default(OTHER)
  isCover     Boolean            @default(false)

  uploadedAt DateTime @default(now())

  @@index([projectId])
}
