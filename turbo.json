{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": ["NODE_ENV", "DATABASE_URL", "DATABASE_URL_UNPOOLED", "BLOB_READ_WRITE_TOKEN", "ADMIN_PASSWORD", "OWNER_EMAIL", "AUTH_SECRET", "VERCEL_API_TOKEN", "VERCEL_MARKETING_PROJECT_ID", "VERCEL_TEAM_ID", "RESEND_API_KEY", "EMAIL_FROM", "SESSION_COOKIE_DOMAIN", "NEXT_PUBLIC_ADMIN_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
